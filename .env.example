# ================================================
# AGROCHAIN AI — ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values.
# NEVER commit .env to version control!
# ================================================

# Django
SECRET_KEY=your-very-secret-django-key-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# LLM Provider: choose 'gemini' or 'openai'
LLM_PROVIDER=gemini

# Google Gemini API Key (free tier available)
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAgR_W8K8wLxe3t6dRQcTyD1HYdVZOvMwU

# OpenAI API Key (optional, if using OpenAI instead)
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# AWS (optional, for S3 media storage — free tier available)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# PostgreSQL (optional, for production)
# DB_NAME=agrochain
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432
